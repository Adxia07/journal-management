{
  "title": "Journal Management API",
  "uid": "journal-api-dashboard",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Запросы в секунду",
      "description": "Количество HTTP-запросов к API за последнюю минуту",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_received_total[1m])",
          "legendFormat": "{{method}} {{path}} {{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Среднее время ответа (мс)",
      "description": "Среднее время обработки HTTP-запросов",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m]) * 1000",
          "legendFormat": "Среднее время (мс)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP Ошибки (5xx)",
      "description": "Количество серверных ошибок — должно быть близко к нулю",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total{code=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Использование памяти процессом",
      "description": "Объём оперативной памяти, используемой процессом API",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "dotnet_total_memory_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 104857600 },
              { "color": "red", "value": 524288000 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Активные потоки .NET",
      "description": "Количество активных потоков в ThreadPool",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "dotnet_threadpool_threads_total",
          "legendFormat": "Всего потоков",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
